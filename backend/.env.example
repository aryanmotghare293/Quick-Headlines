PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# auto selects the first configured provider, then demo data.
# Accepted values: auto, newsapi, gnews, demo
NEWS_PROVIDER=auto
NEWS_API_KEY=
GNEWS_API_KEY=

DEFAULT_COUNTRY=us
DEFAULT_LANGUAGE=en
CACHE_TTL_SECONDS=300
REQUEST_TIMEOUT_MS=8000
ALLOW_DEMO_FALLBACK=true
